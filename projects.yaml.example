# projects.yaml — Project index template
#
# This file maps available projects/workspaces.
# Use with symlinks for quick access + direct navigation.
#
# IMPORTANT: Copy this file to projects.yaml and customize paths for your environment.
# The template uses relative paths from ./repos/ directory.
#
# Directory structure:
#   ./repos/github.com/<owner>/<repo>
#
# Usage:
#   - Read this file to know available projects
#   - Create symlinks with: ./bin/project-indexer add <repo-name> <path>
#   - Or manually: ln -s <path> ./projects/<repo-name>

# === TEMPLATE CONFIGURATION ===
# These paths are relative to ./repos/
# Customize after cloning this repo

# === EXAMPLE: YOUR ORGANIZATION ===
# Replace 'my-org' with your GitHub organization or username
my-org:
  category: my-org
  path: ./repos/github.com/my-org
  description: Root directory for my organization's projects
  subdirs:
    - my-project-1
    - my-project-2

# === EXAMPLE: CLIENTS ===
# Replace with your actual client repos
clients:
  category: clients
  path: ./repos/github.com
  description: Client repositories
  subdirs:
    - client-a
    - client-b

# === PROJECT REGISTRY ===
# Register your projects here after cloning
# Format:
#   repo-name: short name for quick access (used for symlink)
#   path: relative or absolute path to the repo
#   description: what this project is about
#   cloned: true/false - whether you've cloned it

frequent:
  # Uncomment and customize after cloning:
  # - repo-name: my-project
  #   path: ./repos/github.com/my-org/my-project
  #   description: My main project
  #   cloned: false
  #
  # - repo-name: client-project
  #   path: ./repos/github.com/my-org/client-project
  #   description: Client project
  #   cloned: false

# === ADDING NEW PROJECTS ===
# After cloning a repo, add it here:
#
# 1. Run: ./bin/project-indexer add <repo-name> <path>
# 2. Or manually add to the frequent section above
#
# Example:
#   - repo-name: my-project
#     path: ./repos/github.com/my-org/my-project
#     description: My awesome project
#     cloned: true
