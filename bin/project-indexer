#!/usr/bin/env bash
set -euo pipefail

# Project indexer for AI Workspace
# Simple clone + symlink manager
#
# No aliases - symlinks use the repo name directly
#
# Structure:
#   ./repos/github.com/<org>/<repo>/    (gitignored)
#   ./projects/<repo> → <target>          (gitignored)

# Detect workspace root
WORKSPACE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECTS_DIR="${WORKSPACE_ROOT}/projects"
REPOS_DIR="${WORKSPACE_ROOT}/repos"

usage() {
  cat <<EOF
project-indexer - Simple clone + symlink manager

Usage:
  project-indexer init               # Initialize workspace directories
  project-indexer clone <org/repo>  # Clone repo + create symlink
  project-indexer add <path>       # Add symlink for existing repo
  project-indexer remove <repo>     # Remove symlink (keeps repo)
  project-indexer list              # List all symlinks
  project-indexer scan              # Scan repos and symlinks
  project-indexer help             # Show this help

Examples:
  project-indexer init
  project-indexer clone owner/my-project
  project-indexer clone owner/my-other-project
  project-indexer list

Notes:
  - No aliases - symlinks use the repo name directly
  - ./repos/ and ./projects/ are gitignored
EOF
}

cd "$WORKSPACE_ROOT"

case "${1:-}" in
  init)
    echo "=== Initializing AI Workspace ==="
    mkdir -p "$REPOS_DIR/github.com"
    mkdir -p "$PROJECTS_DIR"
    echo "✓ Created:"
    echo "  - repos/     (cloned repos)"
    echo "  - projects/  (symlinks)"
    echo ""
    echo "Next: project-indexer clone owner/my-project"
    ;;

  clone)
    repo="${2:-}"
    [[ -n "$repo" ]] || { echo "Usage: clone <org/repo>"; exit 1; }

    org="${repo%%/*}"
    repo_name="${repo##*/}"
    target_dir="${REPOS_DIR}/github.com/${org}/${repo_name}"

    # Clone if not exists
    if [[ -d "$target_dir" ]]; then
      echo "⚠️  Already cloned: github.com/${org}/${repo_name}"
    else
      mkdir -p "$(dirname "$target_dir")"
      echo "Cloning github.com/${org}/${repo_name}..."
      git clone "git@github.com:${org}/${repo_name}.git" "$target_dir"
    fi

    # Create symlink
    mkdir -p "$PROJECTS_DIR"
    ln -sf "$target_dir" "${PROJECTS_DIR}/${repo_name}"
    echo "✓ Symlink: projects/${repo_name}"
    ;;

  add)
    path="${2:-}"
    [[ -n "$path" ]] || { echo "Usage: add <path-to-repo>"; exit 1; }

    # Resolve path
    if [[ "$path" != /* ]]; then
      path="$(cd "$WORKSPACE_ROOT" && realpath "$path")"
    fi

    [[ -d "$path" ]] || { echo "Error: not a directory: $path"; exit 1; }

    repo_name="$(basename "$path")"
    mkdir -p "$PROJECTS_DIR"
    ln -sf "$path" "${PROJECTS_DIR}/${repo_name}"
    echo "✓ Symlink: projects/${repo_name} → $path"
    ;;

  remove)
    repo="${2:-}"
    [[ -n "$repo" ]] || { echo "Usage: remove <repo>"; exit 1; }
    rm -f "${PROJECTS_DIR}/${repo}"
    echo "✓ Removed: projects/${repo}"
    ;;

  list)
    echo "=== Projects ==="
    if [[ -d "${PROJECTS_DIR}" ]]; then
      for link in "${PROJECTS_DIR}"/*; do
        [[ -L "$link" ]] || continue
        target=$(readlink "$link")
        name=$(basename "$link")
        if [[ -d "$target" ]]; then
          echo "  ✓ $name"
        else
          echo "  ✗ $name (broken)"
        fi
      done
    fi
    ;;

  scan)
    echo "=== Scan ==="
    echo ""
    echo "Symlinks:"
    for link in "${PROJECTS_DIR}"/*; do
      [[ -L "$link" ]] || continue
      name=$(basename "$link")
      echo "  $name ✓"
    done 2>/dev/null || echo "  (none)"

    echo ""
    echo "Repos:"
    if [[ -d "${REPOS_DIR}/github.com" ]]; then
      for repo in "${REPOS_DIR}/github.com"/*/*/; do
        [[ -d "$repo" ]] || continue
        name=$(basename "$repo")
        if [[ -L "${PROJECTS_DIR}/${name}" ]]; then
          echo "  $name ✓"
        else
          echo "  $name (no symlink)"
        fi
      done
    else
      echo "  (none cloned)"
    fi
    ;;

  help|--help|-h)
    usage
    ;;

  *)
    usage
    ;;
esac
