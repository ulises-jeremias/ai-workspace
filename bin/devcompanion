#!/usr/bin/env python3
"""
bin/devcompanion — standalone background job queue for AI Workspace.

Manages a job queue in ~/.local/share/ai-workspace/dev-companion/
(no dependency on any external workstation runner).

If a workstation runner (dots_devcompanion_runner) is available, it will be
used for run-once. Otherwise, a built-in skeleton runner is used.

Usage:
    devcompanion queue <project> [--template <name>] [--request "..."] [--id <id>] [--no-llm]
    devcompanion run-once [--no-llm]
    devcompanion status
    devcompanion sync-todos
    devcompanion done <job-id>
    devcompanion templates
    devcompanion projects
    devcompanion help
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

# ── paths ─────────────────────────────────────────────────────────────────────

WORKSPACE_ROOT = Path(__file__).resolve().parent.parent
PROJECTS_DIR   = WORKSPACE_ROOT / "projects"
TEMPLATES_DIR  = WORKSPACE_ROOT / "templates" / "jobs"
KNOWLEDGE_TODOS = WORKSPACE_ROOT / "knowledge" / "todos" / "pending.md"

# Queue home — standalone, no external dependency
# Override with AI_WORKSPACE_DC_HOME env var for custom locations
_DC_HOME = Path(
    os.environ.get("AI_WORKSPACE_DC_HOME")
    or Path.home() / ".local" / "share" / "ai-workspace" / "dev-companion"
)
QUEUE_PENDING    = _DC_HOME / "queue" / "pending"
QUEUE_PROCESSING = _DC_HOME / "queue" / "processing"
QUEUE_DONE       = _DC_HOME / "queue" / "done"
QUEUE_FAILED     = _DC_HOME / "queue" / "failed"

# Optional external runner (used if available, falls back to skeleton)
# Set AI_WORKSPACE_RUNNER_DIR to point at a directory containing a
# runner module with a main() entry point for full LLM-powered execution.
# If dots-ai is installed, dots-devcompanion provides this runner.
_RUNNER_DIR = Path(
    os.environ.get("AI_WORKSPACE_RUNNER_DIR", "")
    or Path.home() / ".local" / "share" / "dots-ai" / "dev-companion" / "runner"
)


# ── colors ────────────────────────────────────────────────────────────────────

_USE_COLOR = sys.stdout.isatty() and not os.environ.get("NO_COLOR")

def _c(code: str, text: str) -> str:
    return f"\033[{code}m{text}\033[0m" if _USE_COLOR else text

def _blue(t):   return _c("1;34", t)
def _green(t):  return _c("1;32", t)
def _yellow(t): return _c("1;33", t)
def _red(t):    return _c("1;31", t)
def _cyan(t):   return _c("0;36", t)


def log(msg: str):  print(f"{_blue('[devcompanion]')} {msg}")
def ok(msg: str):   print(f"{_green('[devcompanion]')} {msg}")
def warn(msg: str): print(f"{_yellow('[devcompanion]')} {msg}")
def err(msg: str):  print(f"{_red('[devcompanion]')} {msg}", file=sys.stderr)


# ── workstation runner import ─────────────────────────────────────────────────

def _import_runner():
    """Try to import the dots-ai devcompanion runner. Returns (module, None) or (None, reason)."""
    runner_module = _RUNNER_DIR / "runner"
    if not _RUNNER_DIR.is_dir():
        return None, f"runner dir not found: {_RUNNER_DIR}"
    if str(_RUNNER_DIR) not in sys.path:
        sys.path.insert(0, str(_RUNNER_DIR))
    try:
        import dots_devcompanion_runner as r
        return r, None
    except ImportError as e:
        return None, str(e)


# ── helpers ───────────────────────────────────────────────────────────────────

def utc_now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def resolve_project(name: str) -> Path | None:
    """Resolve a project name → real repo path via projects/ symlinks."""
    link = PROJECTS_DIR / name
    if link.is_symlink():
        return link.resolve()
    # fuzzy: partial match on symlink name
    if PROJECTS_DIR.is_dir():
        for entry in PROJECTS_DIR.iterdir():
            if entry.is_symlink() and name in entry.name:
                return entry.resolve()
    return None


def list_projects() -> list[tuple[str, Path | None]]:
    """Return list of (name, resolved_path_or_None) for all indexed projects."""
    if not PROJECTS_DIR.is_dir():
        return []
    result = []
    for entry in sorted(PROJECTS_DIR.iterdir()):
        if entry.is_symlink():
            target = entry.resolve() if entry.resolve().is_dir() else None
            result.append((entry.name, target))
    return result


def load_template(name: str) -> dict:
    """Load a job template YAML. Returns dict with at least 'request'."""
    tpl_file = TEMPLATES_DIR / f"{name}.yaml"
    if not tpl_file.exists():
        err(f"Template not found: {name}  (looked in {TEMPLATES_DIR}/)")
        sys.exit(1)

    text = tpl_file.read_text(encoding="utf-8")
    lines = text.splitlines()

    def _extract(field: str) -> str:
        for i, line in enumerate(lines):
            # Skip comment lines
            if line.lstrip().startswith("#"):
                continue
            # Match `field: |`  (block literal scalar)
            if re.match(rf"^{field}:\s*\|\s*$", line):
                block_lines = []
                for j in range(i + 1, len(lines)):
                    bl = lines[j]
                    # Block ends at a non-indented non-empty line that is a new key
                    if bl and not bl.startswith(" ") and not bl.startswith("\t") and not bl.startswith("#"):
                        break
                    # Skip comment lines inside the block
                    if bl.lstrip().startswith("#"):
                        continue
                    block_lines.append(re.sub(r"^  ", "", bl))
                return "\n".join(block_lines).rstrip()
            # Match `field: "value"`  or  `field: value`
            m = re.match(rf"^{field}:\s+(.+)$", line)
            if m:
                return m.group(1).strip().strip('"').strip("'")
        return ""

    return {
        "name":        _extract("name") or name,
        "description": _extract("description"),
        "request":     _extract("request"),
    }


def read_job(path: Path) -> dict:
    """Read and return a job JSON file as a dict."""
    return json.loads(path.read_text(encoding="utf-8"))


def write_job(path: Path, data: dict):
    """Write a job dict as JSON."""
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")


# ── projects.yaml sync ────────────────────────────────────────────────────────

def sync_projects_yaml():
    """Auto-generate projects.yaml from projects/ symlinks."""
    projects = list_projects()
    if not projects:
        return

    yaml_file = WORKSPACE_ROOT / "projects.yaml"
    lines = [
        "# Auto-generated by bin/devcompanion — do not edit manually",
        f"# Updated: {utc_now()}",
        "",
        "projects:",
    ]
    for name, target in projects:
        if target:
            lines.append(f"  {name}:")
            lines.append(f"    path: {target}")
        else:
            lines.append(f"  {name}:  # broken symlink")

    yaml_file.write_text("\n".join(lines) + "\n", encoding="utf-8")


# ── todos sync ────────────────────────────────────────────────────────────────

def _read_queue_jobs(dirs: list[Path]) -> list[tuple[str, dict]]:
    """Read all .job files from the given queue directories."""
    jobs = []
    for d in dirs:
        if not d.is_dir():
            continue
        for f in sorted(d.iterdir()):
            if f.suffix == ".job":
                try:
                    data = read_job(f)
                    jobs.append((d.name, data))  # (state, job_dict)
                except Exception:
                    pass
    return jobs


def sync_todos():
    """Regenerate knowledge/todos/pending.md from the real queue state."""
    pending_jobs    = _read_queue_jobs([QUEUE_PENDING])
    processing_jobs = _read_queue_jobs([QUEUE_PROCESSING])
    done_jobs       = _read_queue_jobs([QUEUE_DONE])
    failed_jobs     = _read_queue_jobs([QUEUE_FAILED])

    active   = [(s, j) for s, j in pending_jobs + processing_jobs]
    inactive = [(s, j) for s, j in done_jobs + failed_jobs]

    lines = [
        "# Pending Items",
        "",
        "> Auto-generated from the devcompanion queue. Do not edit manually.",
        "> Run `./bin/devcompanion sync-todos` to refresh.",
        "",
        "---",
        "",
    ]

    # Active jobs table
    if active:
        lines += [
            "## Active Jobs",
            "",
            "| Date | Status | Job ID | Project | Request |",
            "|------|--------|--------|---------|---------|",
        ]
        for state, job in active:
            date    = job.get("created_at", "")[:10]
            jid     = job.get("id", "?")
            repo    = Path(job.get("repo_path", "")).name if job.get("repo_path") else "—"
            request = job.get("request", "").split("\n")[0][:80]
            lines.append(f"| {date} | {state} | {jid} | {repo} | {request} |")
        lines.append("")
    else:
        lines += ["## Active Jobs", "", "_No active jobs in queue._", ""]

    lines += ["---", ""]

    # Recently completed (last 10)
    if inactive:
        recent = inactive[-10:]
        lines += [
            "## Recently Completed",
            "",
            "| Date | Status | Job ID | Project |",
            "|------|--------|--------|---------|",
        ]
        for state, job in reversed(recent):
            date = job.get("created_at", "")[:10]
            jid  = job.get("id", "?")
            repo = Path(job.get("repo_path", "")).name if job.get("repo_path") else "—"
            lines.append(f"| {date} | {state} | {jid} | {repo} |")
        lines.append("")
        lines += ["---", ""]

    lines += [
        "## Rules",
        "",
        "- This file is auto-generated — edit via `bin/devcompanion`, not directly",
        "- Active jobs are in the queue directory",
        "- Run `./bin/devcompanion status` for a live view",
        "",
    ]

    KNOWLEDGE_TODOS.parent.mkdir(parents=True, exist_ok=True)
    KNOWLEDGE_TODOS.write_text("\n".join(lines), encoding="utf-8")
    ok(f"Synced {len(active)} active / {len(inactive)} completed jobs → knowledge/todos/pending.md")


# ── subcommands ───────────────────────────────────────────────────────────────

def cmd_queue(args):
    if not args.project:
        err("Usage: devcompanion queue <project> [--template <name>] [--request \"...\"]")
        sys.exit(1)

    # Resolve repo path
    repo_path = resolve_project(args.project)
    if repo_path is None:
        err(f"Project not found: '{args.project}'")
        print()
        projects = list_projects()
        if projects:
            print("Known projects:")
            for name, target in projects:
                status = str(target) if target else _red("(broken)")
                print(f"  {_cyan(f'{name:<30}')} → {status}")
        else:
            print("  (no projects indexed — run: bin/project-indexer clone <org/repo>)")
        sys.exit(1)

    # Build request
    request = ""
    if args.template:
        tpl = load_template(args.template)
        request = tpl["request"]
        if args.request:
            request = f"{request}\n\n---\n\n{args.request}"
    elif args.request:
        request = args.request
    else:
        err("Provide --request or --template")
        sys.exit(1)

    # Build job dict
    job_id = args.id or f"{args.project}-{datetime.now().strftime('%Y%m%d-%H%M%S')}"
    job = {
        "id":         job_id,
        "created_at": utc_now(),
        "request":    request,
        "repo_path":  str(repo_path),
        "llm":        not args.no_llm,
        "limits": {
            "timeout_sec": 1800,
            "max_steps":   25,
        },
        "actions_allowed": ["plan_only"],
    }

    job_file = QUEUE_PENDING / f"{job_id}.job"
    write_job(job_file, job)

    log(f"Project : {args.project}")
    log(f"Repo    : {repo_path}")
    log(f"Job ID  : {job_id}")
    log(f"LLM     : {'enabled' if job['llm'] else 'disabled (skeleton)'}")
    ok(f"Job written → {job_file}")

    # Keep todos in sync
    sync_todos()
    # Keep projects.yaml in sync
    sync_projects_yaml()

    print()
    ok("Next: run `devcompanion run-once` to process, or let the worker pick it up.")
    print(f"      Check status: {_cyan('devcompanion status')}")


def cmd_run_once(args):
    """Run the oldest pending job. Uses dots-ai runner if available, else skeleton."""
    QUEUE_PENDING.mkdir(parents=True, exist_ok=True)
    job_files = sorted(QUEUE_PENDING.glob("*.job"))
    if not job_files:
        ok("No pending jobs.")
        return

    job_file = job_files[0]
    job_id   = job_file.stem
    out_dir  = _DC_HOME / "queue" / "artifacts" / job_id

    log(f"Running job: {job_id}")
    log(f"Artifacts → {out_dir}")

    no_llm = getattr(args, "no_llm", False)

    # ── Try dots-ai runner first ──────────────────────────────────────────
    runner, reason = _import_runner()
    if runner and not no_llm:
        argv = ["--job", str(job_file), "--out", str(out_dir)]
        rc = runner.main(argv)
        if rc is None:
            rc = 0  # treat no explicit return as success
    else:
        if runner is None:
            warn(f"dots-ai runner not available ({reason}). Using skeleton runner.")
        elif no_llm:
            log("--no-llm flag set. Using skeleton runner.")
        rc = _skeleton_run(job_file, out_dir, no_llm=True)

    # ── Move to done/failed ───────────────────────────────────────────────
    if not job_file.exists():
        err(f"Job file missing after run: {job_file.name}")
        # Check if already moved
        if (QUEUE_DONE / job_file.name).exists():
            log("Job already in done/")
        elif (QUEUE_FAILED / job_file.name).exists():
            log("Job already in failed/")
        sync_todos()
        return

    if rc == 0:
        QUEUE_DONE.mkdir(parents=True, exist_ok=True)
        job_file.rename(QUEUE_DONE / job_file.name)
        ok(f"Job done: {job_id}")
        plan_path = out_dir / "plan.md"
        if plan_path.exists():
            print()
            print(_cyan(f"── plan.md {'─' * 50}"))
            print(plan_path.read_text(encoding="utf-8")[:2000])
    else:
        QUEUE_FAILED.mkdir(parents=True, exist_ok=True)
        job_file.rename(QUEUE_FAILED / job_file.name)
        err(f"Job failed: {job_id} (rc={rc})")

    sync_todos()


def _skeleton_run(job_file: Path, out_dir: Path, no_llm: bool = True) -> int:
    """Built-in skeleton runner — generates a basic plan without LLM."""
    out_dir.mkdir(parents=True, exist_ok=True)
    try:
        job = read_job(job_file)
        job_id  = job.get("id", job_file.stem)
        repo    = Path(job.get("repo_path", "")).name or "unknown"
        request = job.get("request", "(no request)")

        plan = f"""# Plan — {job_id}

**Generated**: {utc_now()}
**Mode**: skeleton (no LLM)
**Project**: {repo}

## Request

{request}

## Steps

> This is a skeleton plan. Run without --no-llm for AI-generated steps.

1. Read project README and AGENTS.md
2. Understand existing conventions and patterns
3. Analyze the request in context
4. Implement changes following project conventions
5. Run tests and verify
6. Create PR

## Notes

- Job ID: {job_id}
- Repo path: {job.get("repo_path", "not set")}
"""
        (out_dir / "plan.md").write_text(plan, encoding="utf-8")
        ok(f"Skeleton plan written → {out_dir / 'plan.md'}")
        return 0
    except Exception as e:
        err(f"Skeleton runner failed: {e}")
        return 1


def cmd_status(_args):
    print()
    print(_blue("=== devcompanion queue status ==="))
    print()

    all_states = [
        ("pending",    QUEUE_PENDING,    _yellow),
        ("processing", QUEUE_PROCESSING, _cyan),
        ("done",       QUEUE_DONE,       _green),
        ("failed",     QUEUE_FAILED,     _red),
    ]

    for state, d, color in all_states:
        if not d.is_dir():
            continue
        jobs = list(d.glob("*.job"))
        count = len(jobs)
        print(f"{color(f'{state:<12}')} {count} job(s)")
        for jf in sorted(jobs)[:5]:  # show max 5 per state
            try:
                data = read_job(jf)
                jid     = data.get("id", jf.stem)
                repo    = Path(data.get("repo_path", "")).name or "—"
                request = data.get("request", "").split("\n")[0][:60]
                print(f"  {_cyan(f'{jid:<45}')} [{repo}] {request}")
            except Exception:
                print(f"  {jf.name} (unreadable)")
        if count > 5:
            print(f"  … and {count - 5} more")
        print()

    # Workspace projects
    projects = list_projects()
    print(f"{_blue('indexed projects')}  {len(projects)}")
    for name, target in projects[:8]:
        s = str(target) if target else _red("(broken)")
        print(f"  {_cyan(f'{name:<30}')} → {s}")
    if len(projects) > 8:
        print(f"  … and {len(projects) - 8} more")
    print()


def cmd_sync_todos(_args):
    sync_todos()
    sync_projects_yaml()


def cmd_done(args):
    if not args.job_id:
        err("Usage: devcompanion done <job-id>")
        sys.exit(1)

    jid = args.job_id
    found = False

    for src_dir in (QUEUE_PENDING, QUEUE_PROCESSING, QUEUE_FAILED):
        job_file = src_dir / f"{jid}.job"
        if job_file.exists():
            QUEUE_DONE.mkdir(parents=True, exist_ok=True)
            job_file.rename(QUEUE_DONE / f"{jid}.job")
            ok(f"Moved to done: {jid}")
            found = True
            break

    if not found:
        # Already in done?
        if (QUEUE_DONE / f"{jid}.job").exists():
            ok(f"Job already in done: {jid}")
        else:
            warn(f"Job file not found: {jid}.job (may have already run or never existed)")

    sync_todos()


def cmd_templates(_args):
    print()
    print(_blue("=== Available job templates ==="))
    print()

    if not TEMPLATES_DIR.is_dir():
        warn(f"No templates directory: {TEMPLATES_DIR}")
        return

    for tpl_file in sorted(TEMPLATES_DIR.glob("*.yaml")):
        tpl = load_template(tpl_file.stem)
        desc = tpl.get("description", "")
        print(f"  {_cyan(f'{tpl_file.stem:<25}')} {desc}")

    print()
    print(f"Usage: {_cyan('devcompanion queue <project> --template <name>')}")
    print()


def cmd_projects(_args):
    print()
    print(_blue("=== Indexed projects ==="))
    print()

    projects = list_projects()
    if not projects:
        print("  (no projects indexed)")
    else:
        for name, target in projects:
            s = str(target) if target else _red("(broken symlink)")
            print(f"  {_cyan(f'{name:<30}')} → {s}")

    print()
    print(f"Add a project: {_cyan('bin/project-indexer clone <org/repo>')}")
    print()


def cmd_help(_args=None):
    print(f"""
{_blue('devcompanion')} — standalone background job queue for AI Workspace

{_cyan('Usage:')}
  devcompanion queue <project> [options]   Queue a job for an indexed project
  devcompanion run-once [--no-llm]         Run oldest pending job
  devcompanion status                      Show queue state and indexed projects
  devcompanion sync-todos                  Regenerate knowledge/todos/pending.md from queue
  devcompanion done <job-id>               Move a job to done
  devcompanion templates                   List available job templates
  devcompanion projects                    List indexed projects
  devcompanion help                        Show this help

{_cyan('queue options:')}
  --template <name>    Use a predefined job template
  --request "..."      Custom request (required if no --template)
  --id <id>            Custom job ID (default: <project>-<timestamp>)
  --no-llm             Skip LLM, generate skeleton plan only

{_cyan('Queue path:')}
  {_DC_HOME / "queue"}
  (override with AI_WORKSPACE_DC_HOME env var)

{_cyan('Runner integration:')}
  If dots-ai is installed, uses dots-devcompanion for LLM-powered execution.
  Without dots-ai, the built-in skeleton runner is used.

{_cyan('Examples:')}
  devcompanion queue my-api --template code-review
  devcompanion queue my-api --template investigate --request "slow response on /users"
  devcompanion queue my-api --request "add pagination to GET /users"
  devcompanion run-once
  devcompanion run-once --no-llm    # skeleton plan, no LLM needed
  devcompanion status
  devcompanion done my-api-20260406-120000

{_cyan('Workflow:')}
  1. devcompanion queue <project> --template <template>
  2. devcompanion run-once            (or: let a background worker pick it up)
  3. devcompanion done <job-id>

{_cyan('Docs:')}
  docs/DEVCOMPANION.md
""")


# ── main ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="devcompanion",
        description="Standalone background job queue for AI Workspace",
        add_help=False,
    )
    sub = parser.add_subparsers(dest="command")

    # queue
    p_queue = sub.add_parser("queue")
    p_queue.add_argument("project", nargs="?")
    p_queue.add_argument("--template", "-t")
    p_queue.add_argument("--request",  "-r")
    p_queue.add_argument("--id")
    p_queue.add_argument("--no-llm", action="store_true")

    # run-once
    p_run = sub.add_parser("run-once")
    p_run.add_argument("--no-llm", action="store_true")

    # status
    sub.add_parser("status")

    # sync-todos
    sub.add_parser("sync-todos")

    # done
    p_done = sub.add_parser("done")
    p_done.add_argument("job_id", nargs="?")

    # templates
    sub.add_parser("templates")

    # projects
    sub.add_parser("projects")

    # help
    sub.add_parser("help")

    args = parser.parse_args()

    dispatch = {
        "queue":      cmd_queue,
        "run-once":   cmd_run_once,
        "status":     cmd_status,
        "sync-todos": cmd_sync_todos,
        "done":       cmd_done,
        "templates":  cmd_templates,
        "projects":   cmd_projects,
        "help":       cmd_help,
        None:         cmd_help,
    }

    fn = dispatch.get(args.command, cmd_help)
    fn(args)


if __name__ == "__main__":
    main()
