#!/usr/bin/env bash
# workspace-context — session state snapshot for AI Workspace
# Outputs a summary of current workspace state to inject at session start.
# Usage:
#   ./bin/workspace-context           # Print snapshot to stdout
#   ./bin/workspace-context load packs/<pack>.yaml   # Load a context pack

set -euo pipefail

WORKSPACE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
KNOWLEDGE="${WORKSPACE_ROOT}/knowledge"
PROJECTS_DIR="${WORKSPACE_ROOT}/projects"
PERSONAS_DIR="${WORKSPACE_ROOT}/personas"
PACKS_DIR="${WORKSPACE_ROOT}/packs"

# ── colors ────────────────────────────────────────────────────────────────────
_use_color() { [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; }
blue()   { _use_color && printf '\033[1;34m%s\033[0m\n' "$*" || echo "$*"; }
green()  { _use_color && printf '\033[1;32m%s\033[0m\n' "$*" || echo "$*"; }
yellow() { _use_color && printf '\033[1;33m%s\033[0m\n' "$*" || echo "$*"; }
dim()    { _use_color && printf '\033[0;37m%s\033[0m\n' "$*" || echo "$*"; }

# ── snapshot ──────────────────────────────────────────────────────────────────

cmd_snapshot() {
  echo ""
  blue "=== AI Workspace — Session Context ==="
  echo ""

  # Date
  echo "Date       : $(date '+%Y-%m-%d %H:%M %Z')"
  echo "Workspace  : ${WORKSPACE_ROOT}"
  echo ""

  # Git branch
  if git -C "${WORKSPACE_ROOT}" rev-parse --git-dir > /dev/null 2>&1; then
    branch=$(git -C "${WORKSPACE_ROOT}" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
    echo "Branch     : ${branch}"
  fi
  echo ""

  # Indexed projects
  blue "── Projects ──────────────────────────────────────────────"
  if [[ -d "${PROJECTS_DIR}" ]]; then
    count=0
    while IFS= read -r -d '' link; do
      name=$(basename "$link")
      target=$(readlink -f "$link" 2>/dev/null || echo "(broken)")
      printf "  %-30s → %s\n" "${name}" "${target}"
      (( count++ ))
    done < <(find "${PROJECTS_DIR}" -maxdepth 1 -type l -print0 2>/dev/null | sort -z)
    if [[ $count -eq 0 ]]; then
      dim "  (no projects indexed — run: bin/project-indexer clone owner/repo)"
    fi
  else
    dim "  (projects/ directory not found)"
  fi
  echo ""

  # Pending todos
  blue "── Pending Todos ──────────────────────────────────────────"
  todos_file="${KNOWLEDGE}/todos/pending.md"
  if [[ -f "${todos_file}" ]]; then
    # Show unchecked items only
    unchecked=$(grep -E '^\- \[ \]' "${todos_file}" 2>/dev/null || true)
    if [[ -n "${unchecked}" ]]; then
      echo "${unchecked}" | head -10
    else
      dim "  (no pending todos)"
    fi
  else
    dim "  (no todos file)"
  fi
  echo ""

  # Recent learnings (last 3)
  blue "── Recent Learnings ───────────────────────────────────────"
  learnings_file="${KNOWLEDGE}/learnings/general.md"
  if [[ -f "${learnings_file}" ]]; then
    # Extract last few table rows from the history section
    recent=$(grep -E '^\| [0-9]{4}' "${learnings_file}" 2>/dev/null | tail -3 || true)
    if [[ -n "${recent}" ]]; then
      echo "${recent}"
    else
      dim "  (no learnings recorded yet)"
    fi
  fi
  echo ""

  # Active persona (if any)
  if [[ -d "${PERSONAS_DIR}" ]]; then
    active_persona="${WORKSPACE_ROOT}/.active-persona"
    if [[ -f "${active_persona}" ]]; then
      persona=$(cat "${active_persona}")
      blue "── Active Persona ─────────────────────────────────────────"
      echo "  ${persona}"
      echo ""
    fi
  fi

  # Active pack (if any)
  active_pack="${WORKSPACE_ROOT}/.active-pack"
  if [[ -f "${active_pack}" ]]; then
    pack=$(cat "${active_pack}")
    blue "── Active Pack ────────────────────────────────────────────"
    echo "  ${pack}"
    echo ""
  fi

  blue "──────────────────────────────────────────────────────────"
  echo ""
}

# ── load pack ─────────────────────────────────────────────────────────────────

cmd_load_pack() {
  local pack_file="${1:-}"

  if [[ -z "${pack_file}" ]]; then
    echo "Usage: workspace-context load packs/<pack>.yaml"
    exit 1
  fi

  # Resolve relative to workspace root if not absolute
  if [[ "${pack_file}" != /* ]]; then
    pack_file="${WORKSPACE_ROOT}/${pack_file}"
  fi

  if [[ ! -f "${pack_file}" ]]; then
    echo "Pack not found: ${pack_file}"
    if [[ -d "${PACKS_DIR}" ]]; then
      echo ""
      echo "Available packs:"
      find "${PACKS_DIR}" -name "*.yaml" -maxdepth 2 2>/dev/null | sed "s|${WORKSPACE_ROOT}/||" | sort
    fi
    exit 1
  fi

  # Mark as active
  echo "${pack_file}" > "${WORKSPACE_ROOT}/.active-pack"
  green "Loaded pack: ${pack_file}"
  echo ""

  # Print pack contents as context
  echo "=== Pack Context ==="
  cat "${pack_file}"
  echo ""
}

# ── list personas ─────────────────────────────────────────────────────────────

cmd_personas() {
  blue "── Available Personas ─────────────────────────────────────"
  if [[ -d "${PERSONAS_DIR}" ]]; then
    for f in "${PERSONAS_DIR}"/*.md; do
      [[ -f "$f" ]] || continue
      name=$(basename "${f}" .md)
      # Extract description from first non-empty line after frontmatter or heading
      desc=$(grep -m1 '^>' "${f}" 2>/dev/null | sed 's/^> //' || echo "")
      printf "  %-20s %s\n" "${name}" "${desc}"
    done
  else
    dim "  (no personas directory)"
  fi
  echo ""
  echo "Usage: workspace-context use-persona <name>"
}

cmd_use_persona() {
  local persona="${1:-}"
  if [[ -z "${persona}" ]]; then
    echo "Usage: workspace-context use-persona <name>"
    exit 1
  fi

  local persona_file="${PERSONAS_DIR}/${persona}.md"
  if [[ ! -f "${persona_file}" ]]; then
    echo "Persona not found: ${persona}"
    cmd_personas
    exit 1
  fi

  echo "${persona}" > "${WORKSPACE_ROOT}/.active-persona"
  green "Activated persona: ${persona}"
  echo ""
  cat "${persona_file}"
}

# ── main ──────────────────────────────────────────────────────────────────────

cmd="${1:-snapshot}"
shift || true

case "${cmd}" in
  snapshot|"") cmd_snapshot ;;
  load)        cmd_load_pack "${1:-}" ;;
  personas)    cmd_personas ;;
  use-persona) cmd_use_persona "${1:-}" ;;
  help|--help|-h)
    cat <<'EOF'
workspace-context — AI Workspace session state snapshot

Usage:
  workspace-context                         Print session context snapshot
  workspace-context snapshot                Same as above
  workspace-context load packs/<pack>.yaml  Load a context pack
  workspace-context personas                List available personas
  workspace-context use-persona <name>      Activate a persona

Examples:
  workspace-context
  workspace-context load packs/my-client.yaml
  workspace-context use-persona reviewer
EOF
    ;;
  *)
    echo "Unknown command: ${cmd}"
    echo "Run 'workspace-context help' for usage."
    exit 1
    ;;
esac
