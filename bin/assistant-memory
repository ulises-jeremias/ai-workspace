#!/usr/bin/env python3
"""
bin/assistant-memory — Knowledge base management for AI Workspace

Add, search, list, and inject persistent knowledge across sessions.
"""
from __future__ import annotations

import os
import re
import sys
from datetime import date
from pathlib import Path

WORKSPACE_ROOT = Path(__file__).resolve().parent.parent
KNOWLEDGE = WORKSPACE_ROOT / "knowledge"


# ── colors ─────────────────────────────────────────────────────────────────────

_USE_COLOR = sys.stdout.isatty() and not os.environ.get("NO_COLOR")


def _c(code: str, text: str) -> str:
    return f"\033[{code}m{text}\033[0m" if _USE_COLOR else text


def _blue(t):   return _c("1;34", t)
def _green(t):  return _c("1;32", t)
def _yellow(t): return _c("1;33", t)
def _cyan(t):   return _c("0;36", t)
def _dim(t):    return _c("0;37", t)


# ── file helpers ───────────────────────────────────────────────────────────────

def _read(path: Path) -> str:
    return path.read_text(encoding="utf-8") if path.exists() else ""


def _write(path: Path, content: str):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")


def _prepend_after_marker(path: Path, marker: str, entry: str):
    """Insert entry after the first occurrence of marker in path."""
    content = _read(path)
    if marker not in content:
        # Fallback: append to end
        _write(path, content + "\n" + entry)
        return
    idx = content.index(marker) + len(marker)
    new_content = content[:idx] + "\n" + entry + content[idx:]
    _write(path, new_content)


def _prepend_table_row(path: Path, header_row: str, new_row: str):
    """Insert new_row right after the header row in a markdown table."""
    content = _read(path)
    if header_row not in content:
        _write(path, content + "\n" + new_row)
        return
    idx = content.index(header_row) + len(header_row)
    # Skip the separator row (---) if present
    rest = content[idx:]
    sep_match = re.match(r"\n\|[-| :]+\|", rest)
    if sep_match:
        idx += sep_match.end()
    new_content = content[:idx] + "\n" + new_row + content[idx:]
    _write(path, new_content)


# ── subcommands ────────────────────────────────────────────────────────────────

def cmd_add(args: list[str]):
    type_ = ""
    content = ""
    i = 0
    while i < len(args):
        if args[i] == "--type" and i + 1 < len(args):
            type_ = args[i + 1]
            i += 2
        else:
            content = args[i]
            i += 1

    if not type_ or not content:
        print("Usage: assistant-memory add --type <type> <content>")
        print("Types: skill, process, learning, todo")
        sys.exit(1)

    today = date.today().isoformat()

    if type_ == "skill":
        path = KNOWLEDGE / "skills" / "discovered.md"
        entry = (
            f"\n## {today} - Discovered\n\n"
            f"**What**: {content}\n"
            f"**Status**: pending-review\n\n"
            "---\n"
        )
        _prepend_after_marker(path, "<!-- Add new discoveries below -->", entry)
        print(_green(f"✓ Added skill discovery to {path.relative_to(WORKSPACE_ROOT)}"))

    elif type_ == "process":
        path = KNOWLEDGE / "processes" / "general.md"
        row = f"| {today} | {content} | New pattern |"
        _prepend_table_row(path, "| Date | What | Notes |", row)
        print(_green(f"✓ Added process pattern to {path.relative_to(WORKSPACE_ROOT)}"))

    elif type_ == "learning":
        path = KNOWLEDGE / "learnings" / "general.md"
        row = f"| {today} | {content} | Session |"
        _prepend_table_row(path, "| Date | Learning | Context |", row)
        print(_green(f"✓ Added learning to {path.relative_to(WORKSPACE_ROOT)}"))

    elif type_ == "todo":
        path = KNOWLEDGE / "todos" / "pending.md"
        entry = f"- [ ] {today} - {content}\n"
        _prepend_after_marker(path, "<!-- Add pending items with date added -->", entry)
        print(_green(f"✓ Added todo to {path.relative_to(WORKSPACE_ROOT)}"))

    else:
        print(f"Unknown type: {type_}")
        print("Valid types: skill, process, learning, todo")
        sys.exit(1)


def cmd_search(args: list[str]):
    query = args[0] if args else ""
    if not query:
        print("Usage: assistant-memory search <query>")
        sys.exit(1)

    print(f"\n{_blue(f'=== Searching for: {query} ===')}\n")
    query_lower = query.lower()
    found_any = False

    for md_file in sorted(KNOWLEDGE.rglob("*.md")):
        content = _read(md_file)
        lines = content.splitlines()
        matched_lines = [
            (i + 1, line) for i, line in enumerate(lines)
            if query_lower in line.lower()
        ]
        if matched_lines:
            found_any = True
            rel = md_file.relative_to(WORKSPACE_ROOT)
            print(f"📄 {_cyan(str(rel))}:")
            for lineno, line in matched_lines[:5]:
                print(f"   {_dim(str(lineno) + ':')} {line.strip()}")
            if len(matched_lines) > 5:
                print(f"   {_dim(f'... and {len(matched_lines) - 5} more matches')}")
            print()

    if not found_any:
        print(_dim("  (no results found)"))
    print()


def cmd_list(args: list[str]):
    type_ = args[0] if args else ""

    type_map = {
        "skills":    KNOWLEDGE / "skills",
        "processes": KNOWLEDGE / "processes",
        "learnings": KNOWLEDGE / "learnings",
        "todos":     KNOWLEDGE / "todos",
    }

    if type_ and type_ in type_map:
        d = type_map[type_]
        if d.is_dir():
            for f in sorted(d.iterdir()):
                if f.is_file():
                    print(f.name)
    else:
        print(f"\n{_blue('=== Knowledge Base Contents ===')}\n")
        for section, d in type_map.items():
            print(f"{_cyan(section.capitalize())}:")
            if d.is_dir():
                files = sorted(d.iterdir())
                if files:
                    for f in files:
                        if f.is_file():
                            print(f"  - {f.name}")
                else:
                    print(_dim("  (empty)"))
            else:
                print(_dim("  (not found)"))
            print()


def cmd_todo(_args: list[str]):
    path = KNOWLEDGE / "todos" / "pending.md"
    if path.exists():
        print(path.read_text(encoding="utf-8"))
    else:
        print(_dim("(no todos file found)"))


def cmd_review(_args: list[str]):
    print(f"\n{_blue('=== Session Start Review ===')}\n")

    # Pending todos
    print(f"{_cyan('📋 Pending items:')}")
    todos_path = KNOWLEDGE / "todos" / "pending.md"
    if todos_path.exists():
        content = todos_path.read_text(encoding="utf-8")
        unchecked = [l for l in content.splitlines() if l.startswith("- [ ]")]
        if unchecked:
            for item in unchecked[:10]:
                print(f"  {item}")
        else:
            print(_dim("  (no pending items)"))
    else:
        print(_dim("  (no todos file)"))

    print()

    # Recent learnings
    print(f"{_cyan('📚 Recent learnings:')}")
    learnings_path = KNOWLEDGE / "learnings" / "general.md"
    if learnings_path.exists():
        content = learnings_path.read_text(encoding="utf-8")
        rows = [l for l in content.splitlines() if re.match(r"^\| \d{4}", l)]
        if rows:
            for row in rows[:5]:
                print(f"  {row}")
        else:
            print(_dim("  (no learnings recorded)"))
    print()


def cmd_inject(_args: list[str]):
    """Output a compact context block suitable for injection at session start."""
    print("<!-- assistant-memory inject -->\n")
    print("## Knowledge Base Summary\n")

    # Todos
    todos_path = KNOWLEDGE / "todos" / "pending.md"
    if todos_path.exists():
        content = todos_path.read_text(encoding="utf-8")
        unchecked = [l for l in content.splitlines() if l.startswith("- [ ]")]
        if unchecked:
            print("### Pending Todos\n")
            for item in unchecked[:10]:
                print(item)
            print()

    # Recent learnings
    learnings_path = KNOWLEDGE / "learnings" / "general.md"
    if learnings_path.exists():
        content = learnings_path.read_text(encoding="utf-8")
        rows = [l for l in content.splitlines() if re.match(r"^\| \d{4}", l)]
        if rows:
            print("### Recent Learnings\n")
            print("| Date | Learning | Context |")
            print("|------|----------|---------|")
            for row in rows[:5]:
                print(row)
            print()

    # Processes index
    procs_dir = KNOWLEDGE / "processes"
    if procs_dir.is_dir():
        proc_files = sorted(p.stem for p in procs_dir.iterdir() if p.is_file() and p.suffix == ".md")
        if proc_files:
            print("### Known Processes\n")
            for name in proc_files:
                print(f"- `knowledge/processes/{name}.md`")
            print()

    print("<!-- end assistant-memory inject -->")


def usage():
    print(f"""
{_blue('assistant-memory')} — Manage assistant knowledge base

{_cyan('Usage:')}
  assistant-memory add --type <type> <content>   Add new entry
  assistant-memory search <query>                Search knowledge base
  assistant-memory list [type]                   List entries by type
  assistant-memory todo                          Show pending todos
  assistant-memory review                        Review key items (session start)
  assistant-memory inject                        Output context block for injection
  assistant-memory help                          Show this help

{_cyan('Types for add:')}
  skill      New skill or tool discovery
  process    Process pattern (workflow, tool usage)
  learning   General session learning
  todo       Pending item to follow up

{_cyan('Examples:')}
  assistant-memory add --type learning "Always run tests before committing"
  assistant-memory add --type todo "Investigate slow query in reports endpoint"
  assistant-memory search "deploy"
  assistant-memory list
  assistant-memory inject   # paste output at start of session
""")


# ── main ───────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    cmd = args[0] if args else "help"
    rest = args[1:]

    dispatch = {
        "add":     cmd_add,
        "search":  cmd_search,
        "list":    cmd_list,
        "todo":    cmd_todo,
        "review":  cmd_review,
        "inject":  cmd_inject,
        "help":    lambda _: usage(),
        "--help":  lambda _: usage(),
        "-h":      lambda _: usage(),
    }

    fn = dispatch.get(cmd)
    if fn:
        fn(rest)
    else:
        print(f"Unknown command: {cmd}")
        usage()
        sys.exit(1)


if __name__ == "__main__":
    main()
